# ============================================================================
#  SLM Test Generator — Backend · Variables de entorno (PLANTILLA versionada)
# ----------------------------------------------------------------------------
#  Esta plantilla SÍ se versiona. Tu archivo real `.env` NO (está en .gitignore).
#
#  Para desplegar:
#     cp .env.example .env        # Linux/macOS  (desde la carpeta backend/)
#     Copy-Item .env.example .env # Windows (PowerShell)
#  y ajusta OLLAMA_HOST si tu Ollama no está en el puerto estándar.
#
#  docker-compose.yml carga backend/.env con `env_file`.
# ============================================================================

# URL del servicio Ollama que usa el backend.
#  - Ollama local estándar dentro de Docker:   http://host.docker.internal:11434
#  - Ollama en otro host/puerto (de terceros):  http://<host>:<puerto>
#  - Modo desarrollo sin Docker (host):         http://localhost:11434
#  IMPORTANTE: el puerto debe COINCIDIR con el puerto en el que escucha Ollama.
OLLAMA_HOST=http://host.docker.internal:11434

# Timeout (segundos) por solicitud HTTP a Ollama.
OLLAMA_TIMEOUT=300

# Modelo de embeddings del RAG (si falta, el RAG degrada a TF-IDF).
OLLAMA_EMBED_MODEL=nomic-embed-text

# Inyección de lecciones globales por defecto (0/false/no la desactiva).
GLOBAL_LESSONS_ENABLED=1

# Timeout (segundos) de la ejecución de pytest.
PYTEST_TIMEOUT_S=120

# Salida de Python sin buffer (logs en vivo).
PYTHONUNBUFFERED=1

# ----------------------------------------------------------------------------
# Variables EXCLUSIVAS del script de ablación por CLI (backend/ablacion_lecciones.py).
# NO afectan al servicio web; descoméntalas solo si ejecutas ese script.
# ----------------------------------------------------------------------------
# ABLATION_URL=http://localhost:8000
# ABLATION_MODEL=qwen2.5-coder:3b
# REPS=5
# ABLATION_TIMEOUT=1800
